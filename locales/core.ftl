en = English

# A collection of pre-escaped elements used throughout the translation files
-redirect-register = <a class="link tab" data-tab-id="2">{ $text }</a>
-redirect-login = <a class="link tab tab-active" data-tab-id="1">{ $text }</a>
-redirect-geolocation-api = <a class="link" href="https://www.abstractapi.com/ip-geolocation-api">{ $text }</a>
-redirect-guidelines = <a class="link" href="/guidelines">{ $text }</a>

-record-approved-styled = <span style="background-color: #E9FAE3">{ record-approved }</span>
-record-submitted-styled = <span style="background-color: #F7F7E0">{ record-submitted }</span>
-record-rejected-styled = <span style="background-color: #F8DCE4">{ record-rejected }</span>
-record-underconsideration-styled = <span style="background-color: #D8EFF3">{ record-underconsideration }</span>